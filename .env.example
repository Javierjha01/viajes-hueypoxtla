# Copia este archivo a .env y rellena con tus valores.
# Las variables con prefijo VITE_ se exponen al frontend (Vite).

# Firebase (Web config)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Cloud Messaging (notificaciones push). Clave en Firebase Console > Configuración del proyecto > Cloud Messaging > Certificados de push web.
VITE_FIREBASE_VAPID_KEY=

# Mapbox (mapas)
VITE_MAPBOX_ACCESS_TOKEN=
