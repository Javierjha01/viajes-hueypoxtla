rules_version = '2';
// Desplegar con: firebase deploy --only storage
// (tras firebase init y configurar Storage)

service firebase.storage {
  match /b/{bucket}/o {
    // El usuario solo puede leer y escribir en su propia carpeta de documentación
    match /users/{userId}/documents/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
