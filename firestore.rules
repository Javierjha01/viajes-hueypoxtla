rules_version = '2';
// Desplegar con: firebase deploy --only firestore:rules
// (desde el directorio del proyecto tras firebase init)

service cloud.firestore {
  match /databases/{database}/documents {
    // Usuario solo puede leer y escribir su propio perfil (rol, email, etc.)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // El resto de colecciones se añadirán con el flujo de viajes
  }
}
